---
import { Icon } from "astro-icon/components";
import ThemePicker from "./ThemePicker.jsx";
---

<nav
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b nav-slide-in"
    style="background-color: var(--nav-bg); border-color: var(--bg-border);"
>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <a href="#hero" class="text-2xl font-bold gradient-text">Z</a>

            <div class="hidden md:flex items-center gap-8">
                <a
                    href="#about"
                    class="hover:text-accent transition-colors duration-200"
                    style="color: var(--text-secondary);">About</a
                >
                <a
                    href="#skills"
                    class="hover:text-accent transition-colors duration-200"
                    style="color: var(--text-secondary);">Skills</a
                >
                <a
                    href="#projects"
                    class="hover:text-accent transition-colors duration-200"
                    style="color: var(--text-secondary);">Projects</a
                >
                <a
                    href="#contact"
                    class="hover:text-accent transition-colors duration-200"
                    style="color: var(--text-secondary);">Contact</a
                >
                <ThemePicker client:idle />
            </div>

            <div class="flex items-center gap-2 md:hidden">
                <ThemePicker client:idle />
                <button
                    id="mobile-menu-btn"
                    aria-label="Toggle menu"
                    class="mobile-menu-btn"
                    style="color: var(--text-primary);"
                >
                    <Icon
                        id="menu-icon"
                        name="lucide:menu"
                        width="24"
                        height="24"
                    />
                    <Icon
                        id="close-icon"
                        name="lucide:x"
                        width="24"
                        height="24"
                        style="display:none"
                    />
                </button>
            </div>
        </div>
    </div>

    <div
        id="mobile-menu"
        class="md:hidden border-t overflow-hidden"
        style="max-height:0; transition: max-height 0.3s ease; background-color: var(--bg-secondary); border-color: var(--bg-border);"
    >
        <div class="px-4 py-4 space-y-3">
            <a
                href="#about"
                class="block hover:text-accent transition-colors duration-200"
                style="color: var(--text-secondary);"
                onclick="closeMobileMenu()">About</a
            >
            <a
                href="#skills"
                class="block hover:text-accent transition-colors duration-200"
                style="color: var(--text-secondary);"
                onclick="closeMobileMenu()">Skills</a
            >
            <a
                href="#projects"
                class="block hover:text-accent transition-colors duration-200"
                style="color: var(--text-secondary);"
                onclick="closeMobileMenu()">Projects</a
            >
            <a
                href="#contact"
                class="block hover:text-accent transition-colors duration-200"
                style="color: var(--text-secondary);"
                onclick="closeMobileMenu()">Contact</a
            >
        </div>
    </div>
</nav>

<script>
    (function () {
        var btn = document.getElementById("mobile-menu-btn");
        var menu = document.getElementById("mobile-menu");
        var menuIcon = document.getElementById("menu-icon");
        var closeIcon = document.getElementById("close-icon");
        if (!btn || !menu) return;
        var isOpen = false;
        btn.addEventListener("click", function () {
            isOpen = !isOpen;
            menu.style.maxHeight = isOpen ? menu.scrollHeight + "px" : "0";
            menuIcon.style.display = isOpen ? "none" : "";
            closeIcon.style.display = isOpen ? "" : "none";
        });
        window.closeMobileMenu = function () {
            isOpen = false;
            menu.style.maxHeight = "0";
            menuIcon.style.display = "";
            closeIcon.style.display = "none";
        };
    })();
</script>
