---
import { Icon } from 'astro-icon/components'

const languageColors = {
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Java: '#b07219',
  'C++': '#f34b7d',
  C: '#555555',
  'C#': '#178600',
  Go: '#00ADD8',
  Rust: '#dea584',
  Ruby: '#701516',
  PHP: '#4F5D95',
  Swift: '#F05138',
  Kotlin: '#A97BFF',
  Dart: '#00B4AB',
  Shell: '#89e051',
  Lua: '#000080',
  Vue: '#41b883',
  Svelte: '#ff3e00',
}

let projects = []
let fetchError = false

try {
  const res = await fetch('https://api.github.com/users/zaheen4/repos?sort=updated&per_page=100')
  if (res.ok) {
    const data = await res.json()
    projects = data
      .filter((repo) => !repo.fork)
      .sort((a, b) => (b.stargazers_count || 0) - (a.stargazers_count || 0))
      .slice(0, 4)
      .map((repo) => ({
        name: repo.name,
        description: repo.description || 'No description provided.',
        language: repo.language,
        stars: repo.stargazers_count,
        forks: repo.forks_count,
        url: repo.html_url,
        color: repo.language ? languageColors[repo.language] : 'var(--accent)',
      }))
  } else {
    fetchError = true
  }
} catch {
  fetchError = true
}
---

<section id="projects" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="section-reveal text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-1">
        Featured <span class="gradient-text">Projects</span>
      </h2>
      <div class="section-underline mb-4"></div>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
        A selection of things I've built and contributed to
      </p>
    </div>

    {fetchError && projects.length === 0 ? (
      <p class="text-center py-12" style="color: #ef4444;">
        Unable to load projects at this time.
      </p>
    ) : (
      <div class="stagger-grid grid md:grid-cols-2 gap-6" id="projects-grid">
        {projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="glow-card p-6 block group stagger-item"
          >
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-xl font-semibold group-hover:text-accent transition-colors">
                {project.name}
              </h3>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="flex-shrink-0 ml-4 group-hover:text-accent transition-colors"
                style="color: var(--text-muted);"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <p class="mb-4 text-sm leading-relaxed" style="color: var(--text-secondary);">
              {project.description}
            </p>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                {project.language && (
                  <div class="flex items-center gap-2">
                    <span
                      class="w-3 h-3 rounded-full"
                      style={`background-color: ${project.color};`}
                    />
                    <span class="text-sm" style="color: var(--text-muted);">
                      {project.language}
                    </span>
                  </div>
                )}
                {project.stars > 0 && (
                  <div class="flex items-center gap-1" style="color: var(--text-muted);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#eab308" stroke="none">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                    <span class="text-sm">{project.stars}</span>
                  </div>
                )}
                {project.forks > 0 && (
                  <div class="flex items-center gap-1" style="color: var(--text-muted);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="18" r="3"/>
                      <circle cx="6" cy="6" r="3"/>
                      <circle cx="18" cy="6" r="3"/>
                      <path d="M18 9v1a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9"/>
                      <path d="M12 12v3"/>
                    </svg>
                    <span class="text-sm">{project.forks}</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="text-center mt-12">
      <a
        href="https://github.com/zaheen4"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 border rounded-lg transition-colors duration-200"
        style="border-color: var(--bg-border); color: var(--text-primary);"
      >
        View All on GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { animate, stagger } from 'animejs'

  var grid = document.getElementById('projects-grid')
  if (grid && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var cards = entry.target.querySelectorAll('.stagger-item')
          if (cards.length) {
            animate(cards, {
              opacity: [0, 1],
              translateY: [20, 0],
              delay: stagger(150),
              ease: 'outBack',
              duration: 600,
            })
          }
          observer.unobserve(entry.target)
        }
      })
    }, { threshold: 0.2 })
    observer.observe(grid)
  }
</script>
