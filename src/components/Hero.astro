---
import { Icon } from 'astro-icon/components';
---

<section id="hero" class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden px-4">
  <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);"></div>

  <div class="relative z-10 text-center">
    <p class="hero-fade-in text-accent-light text-lg mb-4 tracking-wide" style="--delay: 0.2s; --duration: 0.5s; --start-y: 20px;">
      Hello, I'm
    </p>

    <h1 class="hero-fade-in text-5xl sm:text-7xl lg:text-8xl font-bold mb-6" style="--delay: 0.4s; --duration: 0.6s; --start-y: 30px;">
      <span class="gradient-text">Mir Zaheen Waseet</span>
    </h1>

    <p class="hero-fade-in text-xl sm:text-2xl max-w-2xl mx-auto mb-8" style="--delay: 0.6s; --duration: 0.5s; --start-y: 20px; color: var(--text-secondary);">
      Building tools that automate the boring stuff
    </p>

    <div class="hero-fade-in flex gap-4 justify-center" style="--delay: 0.8s; --duration: 0.5s;">
      <a href="#projects" class="px-6 py-3 rounded-lg transition-colors duration-200 font-medium text-white" style="background-color: var(--accent);" onmouseenter="this.style.backgroundColor='var(--accent-light)'" onmouseleave="this.style.backgroundColor='var(--accent)'">
        View My Work
      </a>
      <a href="#contact" class="px-6 py-3 border rounded-lg transition-colors duration-200 font-medium" style="border-color: var(--bg-border); color: var(--text-primary);">
        Get In Touch
      </a>
    </div>
  </div>

  <a href="#about" class="hero-fade-in mt-8" style="--delay: 1.2s;">
    <div class="chevron-bounce" style="color: var(--text-muted);">
      <Icon name="lucide:chevron-down" width="32" height="32" />
    </div>
  </a>
</section>
