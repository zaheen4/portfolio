---
import { Icon } from 'astro-icon/components';
---

<section id="hero" aria-label="Hero" class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden px-4">
  <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);"></div>

  <div class="relative z-10 text-center">
    <p id="hero-greeting" class="text-accent-light text-lg mb-4 tracking-wide" style="opacity: 0;">
      Hello, I'm
    </p>

    <h1 class="text-5xl sm:text-7xl lg:text-8xl font-bold mb-6">
      <span class="gradient-text" id="hero-title">Mir Zaheen Waseet</span>
    </h1>

    <p class="hero-fade-in text-xl sm:text-2xl max-w-2xl mx-auto mb-8" style="--delay: 1.8s; --duration: 0.5s; --start-y: 20px; color: var(--text-secondary);">
      Building tools that automate the boring stuff
    </p>

    <div class="hero-fade-in flex gap-4 justify-center" style="--delay: 2.0s; --duration: 0.5s;">
      <a href="#projects" class="btn-primary px-6 py-3 rounded-lg font-medium">
        View My Work
      </a>
      <a href="#contact" class="px-6 py-3 border rounded-lg transition-colors duration-200 font-medium" style="border-color: var(--bg-border); color: var(--text-primary);">
        Get In Touch
      </a>
    </div>
  </div>

  <a href="#about" aria-label="Scroll to About section" class="hero-fade-in mt-8" style="--delay: 2.2s;">
    <div class="chevron-bounce" style="color: var(--text-muted);">
      <Icon name="lucide:chevron-down" width="32" height="32" />
    </div>
  </a>
</section>

<style>
  .btn-primary {
    background-color: var(--accent);
    color: white;
    transition: background-color 0.2s ease;
  }
  .btn-primary:hover {
    background-color: var(--accent-light);
  }
</style>

<script>
  import { animate, stagger } from 'animejs'

  // Greeting letter stagger
  var greetingEl = document.getElementById('hero-greeting')
  if (greetingEl) {
    var text = greetingEl.textContent || ''
    greetingEl.innerHTML = text.split('').map(function (char) {
      if (char === ' ') return '<span class="greeting-letter" style="display:inline-block;opacity:0">&nbsp;</span>'
      return '<span class="greeting-letter" style="display:inline-block;opacity:0">' + char + '</span>'
    }).join('')
    greetingEl.style.opacity = '1'
    animate('.greeting-letter', {
      opacity: [0, 1],
      translateY: [15, 0],
      duration: 400,
      delay: stagger(40),
      ease: 'outBack',
    })
  }

  // Name mask sweep (delayed to overlap with greeting)
  var title = document.getElementById('hero-title')
  if (title) {
    title.style.webkitMaskImage = 'linear-gradient(to right, transparent, transparent)'
    title.style.maskImage = 'linear-gradient(to right, transparent, transparent)'
    setTimeout(function () {
      var state = { t: 0 }
      animate(state, {
        t: 1,
        duration: 1500,
        ease: 'inOutCubic',
        onUpdate: function () {
          var progress = state.t * 100
          var grad = 'linear-gradient(to right, black, black ' + progress + '%, transparent ' + (progress + 15) + '%, transparent 100%)'
          title.style.webkitMaskImage = grad
          title.style.maskImage = grad
        },
      })
    }, 300)
  }
</script>
