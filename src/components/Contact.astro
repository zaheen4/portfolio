---
import { Icon } from "astro-icon/components";

const contacts = [
    {
        name: "Email",
        handle: "zwaseet@gmail.com",
        icon: "lucide:mail",
        href: "mailto:zwaseet@gmail.com",
        color: "#ea4335",
    },
    {
        name: "LinkedIn",
        handle: "mir-zaheen-waseet",
        icon: "simple-icons:linkedin",
        href: "https://www.linkedin.com/in/mir-zaheen-waseet",
        color: "#0077b5",
    },
    {
        name: "Facebook",
        handle: "zaheen.4",
        icon: "simple-icons:facebook",
        href: "https://www.facebook.com/zaheen.4",
        color: "#1877f2",
    },
    {
        name: "Discord",
        handle: "@zaheen4",
        icon: "simple-icons:discord",
        href: "https://discord.com/users/353566198304342016",
        color: "#5865f2",
    },
];
---

<section
    id="contact"
    aria-labelledby="contact-heading"
    class="py-24 px-4"
    style="background-color: var(--bg-secondary);"
>
    <div class="max-w-4xl mx-auto text-center">
        <div class="section-reveal">
            <h2 id="contact-heading" class="text-3xl sm:text-4xl font-bold mb-1">
                Get In <span class="gradient-text">Touch</span>
            </h2>
            <div class="section-underline mb-4"></div>
            <p
                class="text-lg max-w-xl mx-auto mb-12"
                style="color: var(--text-secondary);"
            >
                Have a project in mind or just want to chat? Feel free to reach
                out through any of these channels.
            </p>
        </div>

        <div class="flex flex-wrap justify-center gap-4" id="contact-cards">
            {
                contacts.map((contact, i) => (
                    <a
                        href={contact.href}
                        target={
                            contact.href.startsWith("http")
                                ? "_blank"
                                : undefined
                        }
                        rel={
                            contact.href.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                        }
                        class="contact-chip"
                        style={`
            opacity: 0;
            transform: translateY(20px);
            --chip-color: ${contact.color};
            --i: ${i};
          `}
                    >
                        <Icon
                            name={contact.icon}
                            width="18"
                            height="18"
                            style={`color: ${contact.color}; flex-shrink: 0;`}
                            aria-hidden="true"
                        />
                        <div class="text-left">
                            <div class="text-sm font-medium">
                                {contact.name}
                            </div>
                            <div class="contact-handle">{contact.handle}</div>
                        </div>
                        {contact.href.startsWith("http") && (
                            <span class="sr-only">(opens in new tab)</span>
                        )}
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .contact-chip {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1.1rem;
        border-radius: 999px;
        border: 1px solid var(--bg-border);
        background: color-mix(in srgb, var(--bg-card) 65%, transparent);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        cursor: pointer;
        transition: border-color 0.25s ease;
        text-decoration: none;
    }

    .contact-chip::before {
        content: '';
        position: absolute;
        top: -4px;
        left: 10%;
        width: 80%;
        height: 10px;
        border-radius: 50%;
        background: radial-gradient(ellipse,
            color-mix(in srgb, var(--chip-color) 40%, transparent),
            transparent 70%
        );
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
    }

    .contact-chip:hover::before {
        opacity: 1;
    }

    .contact-chip:hover {
        transform: translateY(-2px);
        border-color: var(--chip-color);
    }

    .contact-chip:hover .contact-handle {
        color: color-mix(in srgb, var(--chip-color) 80%, var(--text-primary));
    }

    .contact-handle {
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.1;
        transition: color 0.25s ease;
    }
</style>

<script>
    import { animate, stagger } from "animejs";

    var container = document.getElementById("contact-cards");
    if (container && "IntersectionObserver" in window) {
        var observer = new IntersectionObserver(
            function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        var chips =
                            entry.target.querySelectorAll(".contact-chip");
                        if (chips.length) {
                            animate(chips, {
                                opacity: [0, 1],
                                translateY: [20, 0],
                                delay: stagger(100),
                                ease: "outBack",
                                duration: 600,
                                onComplete: function () {
                                    chips.forEach(function (chip) {
                                        chip.style.transform = "";
                                    });
                                },
                            });
                        }
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.2 },
        );
        observer.observe(container);
    }
</script>
