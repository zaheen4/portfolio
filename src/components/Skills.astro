---
import { Icon } from 'astro-icon/components';

const rows = [
  [
    { name: 'Python', icon: 'simple-icons:python', color: '#3776AB' },
    { name: 'JavaScript', icon: 'simple-icons:javascript', color: '#F7DF1E' },
    { name: 'TypeScript', icon: 'simple-icons:typescript', color: '#3178C6' },
    { name: 'Dart', icon: 'simple-icons:dart', color: '#0175C2' },
  ],
  [
    { name: 'React', icon: 'simple-icons:react', color: '#61DAFB' },
    { name: 'Node.js', icon: 'simple-icons:nodedotjs', color: '#339933' },
    { name: 'Flutter', icon: 'simple-icons:flutter', color: '#02569B' },
    { name: 'Astro', icon: 'simple-icons:astro', color: '#BC52EE' },
  ],
  [
    { name: 'Web Scraping', icon: 'lucide:terminal', color: 'var(--accent)' },
    { name: 'Automation', icon: 'lucide:cpu', color: '#06b6d4' },
    { name: 'Git', icon: 'simple-icons:git', color: '#F05032' },
    { name: 'MySQL', icon: 'simple-icons:mysql', color: '#4479A1' },
  ],
];
---

<section id="skills" class="py-24 px-4" style="background-color: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto">
    <div class="section-reveal text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-1">
        My <span class="gradient-text">Skills</span>
      </h2>
      <div class="section-underline mb-4"></div>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
        Technologies and tools I work with to bring ideas to life
      </p>
    </div>

    <div class="flex flex-col items-center gap-8" id="skills-rows">
      {rows.map((row, ri) => (
        <div class="w-full flex flex-col items-center gap-4">
          {ri > 0 && (
            <div class="row-divider w-1/2 h-px" style="background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 25%, transparent), transparent);"></div>
          )}
          <div class="stagger-grid flex flex-wrap justify-center gap-5">
            {row.map((skill, si) => (
              <div
                class="skill-chip"
                style={`
                  opacity: 0;
                  transform: translateY(20px);
                  --i: ${si};
                  --chip-color: ${skill.color};
                `}
              >
                <Icon name={skill.icon} width="18" height="18" style={`color: ${skill.color}; flex-shrink: 0;`} />
                <span>{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--bg-border);
    background: color-mix(in srgb, var(--bg-card) 65%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: default;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .skill-chip:hover {
    transform: translateY(-2px);
    border-color: var(--chip-color);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--chip-color) 25%, transparent);
  }

  @keyframes chip-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
  }

  .skill-chip.is-float {
    animation: chip-float 3s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.15s);
  }

  .skill-chip.is-float:hover {
    animation-play-state: paused;
  }

  .row-divider {
    opacity: 0;
    transform: scaleX(0);
  }
</style>

<script>
  import { animate, stagger } from 'animejs'

  var container = document.getElementById('skills-rows')
  if (container && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var grids = entry.target.querySelectorAll('.stagger-grid')
          var rowStart = 0
          grids.forEach(function (grid, ri) {
            var chips = grid.querySelectorAll('.skill-chip')
            var divider = grid.parentElement.querySelector('.row-divider')

            if (divider) {
              animate(divider, {
                opacity: [0, 1],
                scaleX: [0, 1],
                duration: 400,
                ease: 'outCubic',
                delay: rowStart,
              })
            }

            if (chips.length) {
              animate(chips, {
                opacity: [0, 1],
                translateY: [20, 0],
                delay: stagger(80, { start: rowStart }),
                ease: 'outBack',
                duration: 600,
                onComplete: function () {
                  chips.forEach(function (chip) {
                    chip.style.transform = ''
                    chip.classList.add('is-float')
                  })
                },
              })
            }

            rowStart += 250
          })
          observer.unobserve(entry.target)
        }
      })
    }, { threshold: 0.2 })
    observer.observe(container)
  }
</script>
